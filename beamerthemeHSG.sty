% beamerthemeHSG.sty
% Beamer theme replicating the University of St. Gallen (HSG) PowerPoint template.
% Required image assets — the theme looks for them under ./assets/ first,
% then ./ (flat layout), then ../assets/. Both the organised repo layout
% and the flat layout produced by bin/new-deck.sh work.
%
%   hsg-logo-en.pdf, hsg-logo-de.pdf  vector logos (official Wikimedia SVGs)
%   hsg-logo-cover.png                logo + institute subtitle (raster)
%   hsg-badge.png                     green frame around the cover photo
%   hsg-agenda-texture-portrait.jpg   concrete texture for the agenda
%   hsg-closing-campus.jpg            campus photo for the closing slide
%   hsg-closing-logo-band.png         accreditation strip for the closing
%
% Usage in a presentation:
%   \documentclass[aspectratio=169]{beamer}
%   \usetheme{HSG}
%   \author{...}
%   \title{...}
%   \subtitle{...}       % second title line
%   \institute{...}      % course / institute line
%   \date{...}
%   \newcommand{\coursefooter}{Computer Networks} % shown in the footer
%
\ProvidesPackage{beamerthemeHSG}[2026/04/23 HSG Beamer Theme]

\RequirePackage{tikz}
\RequirePackage{xcolor}
\RequirePackage{graphicx}
\RequirePackage{ifthen}
\RequirePackage{pgffor}
\usetikzlibrary{positioning,shapes.geometric,calc,decorations.pathmorphing}

% Asset resolution paths. The theme looks for hsg-* image files in this
% order: ./assets/, ./, then ../assets/ (for examples/ subfolder usage).
% This way users can keep the repo's organised layout OR copy assets
% flat next to their .tex (e.g. via bin/new-deck.sh) — both work.
\graphicspath{{./assets/}{./}{../assets/}}

% ---------------------------------------------------------------------------
% Colours (from theme1.xml of the HSG PowerPoint template)
% ---------------------------------------------------------------------------
\definecolor{HSGgreen}{HTML}{00802F}   % primary brand green
\definecolor{HSGgreenDark}{HTML}{0A5F2D}
\definecolor{HSGbluegrey}{HTML}{73A5AF}
\definecolor{HSGsand}{HTML}{E1D7C3}
\definecolor{HSGcoral}{HTML}{EB6969}
\definecolor{HSGyellow}{HTML}{FFF04B}
\definecolor{HSGtext}{HTML}{2E2E2E}
\definecolor{HSGmuted}{HTML}{7A7A7A}

% ---------------------------------------------------------------------------
% Fonts. HSG corporate identity uses two families:
%
%   Sans  ..... Gill Sans MT Pro / Gill Sans Nova   (proprietary, Monotype)
%               Open clone vendored: Gillius ADF (Arkandis Digital Foundry)
%   Serif ..... Palatino OTF                        (proprietary, Linotype)
%               Open clone vendored: TeX Gyre Pagella (GUST e-foundry)
%
% Slides are sans-dominant; the serif family is available via \rmfamily
% or \textrm{...} for body text in formal docs. Three compile paths:
%
%   pdflatex ..... Lato (sans) + mathpazo (Palatino-like serif)
%   xe/lualatex .. Vendored Gillius ADF + TeX Gyre Pagella from ./fonts/
%
% Compile with xelatex or lualatex for the official HSG look.
% ---------------------------------------------------------------------------
\RequirePackage{iftex}
\ifPDFTeX
  \RequirePackage[default]{lato}
  \RequirePackage{mathpazo}    % Palatino-clone serif for \rmfamily / \textrm
  \RequirePackage[T1]{fontenc}
  \PackageWarning{beamerthemeHSG}{%
    Compiled with pdflatex; falling back to Lato (sans) + mathpazo (serif).\MessageBreak
    For the official HSG look, switch the compiler to xelatex or lualatex\MessageBreak
    (the theme will pick up fonts/ automatically)}%
\else
  \RequirePackage{fontspec}
  % Prefer the vendored Gillius ADF + TeX Gyre Pagella OTFs under ./fonts/
  % (deterministic, independent of TeX Live's font collection on the host).
  \IfFileExists{fonts/GilliusADF-Regular.otf}{%
    \setsansfont{GilliusADF}[%
      Path=./fonts/, Extension=.otf,
      UprightFont=*-Regular,
      ItalicFont=*-Italic,
      BoldFont=*-Bold,
      BoldItalicFont=*-BoldItalic,
      Ligatures=TeX]%
  }{%
    \IfFontExistsTF{Gill Sans Nova}{%
      \setsansfont{Gill Sans Nova}[Ligatures=TeX, UprightFont={* Light}, BoldFont={* Book}]%
    }{%
      \IfFontExistsTF{Gillius ADF}{%
        \setsansfont{Gillius ADF}[Ligatures=TeX]%
        \PackageWarning{beamerthemeHSG}{%
          Using system-installed Gillius ADF (TeX Live).\MessageBreak
          For reproducible rendering, copy the OTFs into ./fonts/}%
      }{%
        \setsansfont{TeX Gyre Heros}[Ligatures=TeX]%
        \PackageWarning{beamerthemeHSG}{%
          No Gill-Sans family available; falling back to TeX Gyre Heros.\MessageBreak
          Drop GilliusADF-{Regular,Italic,Bold,BoldItalic}.otf into ./fonts/\MessageBreak
          to get the official HSG look}%
      }%
    }%
  }%
  % Serif: TeX Gyre Pagella (open Palatino clone). Vendored under fonts/.
  \IfFileExists{fonts/texgyrepagella-regular.otf}{%
    \setmainfont{texgyrepagella}[%
      Path=./fonts/, Extension=.otf,
      UprightFont=*-regular,
      ItalicFont=*-italic,
      BoldFont=*-bold,
      BoldItalicFont=*-bolditalic,
      Ligatures=TeX]%
  }{%
    \IfFontExistsTF{TeX Gyre Pagella}{%
      \setmainfont{TeX Gyre Pagella}[Ligatures=TeX]%
    }{%
      \PackageWarning{beamerthemeHSG}{%
        TeX Gyre Pagella not found; \rmfamily will use the LaTeX default.\MessageBreak
        Drop texgyrepagella-{regular,italic,bold,bolditalic}.otf into ./fonts/}%
    }%
  }%
\fi
\renewcommand{\familydefault}{\sfdefault}

% ---------------------------------------------------------------------------
% Beamer colour setup
% ---------------------------------------------------------------------------
\setbeamercolor{normal text}{fg=HSGtext, bg=white}
\setbeamercolor{structure}{fg=HSGgreen}
\setbeamercolor{alerted text}{fg=HSGgreen}
\setbeamercolor{title}{fg=HSGtext}
\setbeamercolor{subtitle}{fg=HSGtext}
\setbeamercolor{frametitle}{fg=HSGtext}
\setbeamercolor{itemize item}{fg=HSGtext}
\setbeamercolor{itemize subitem}{fg=HSGtext}
\setbeamercolor{enumerate item}{fg=HSGtext}
\setbeamercolor{footline}{fg=HSGmuted}

% ---------------------------------------------------------------------------
% Fonts configured for Beamer
% ---------------------------------------------------------------------------
\setbeamerfont{title}{series=\mdseries, size=\huge}
\setbeamerfont{subtitle}{series=\mdseries, size=\Large}
\setbeamerfont{author}{size=\small}
\setbeamerfont{institute}{size=\footnotesize}
\setbeamerfont{date}{size=\footnotesize}
\setbeamerfont{frametitle}{series=\mdseries, size=\LARGE}
\setbeamerfont{framesubtitle}{series=\mdseries, size=\footnotesize, shape=\normalfont}
\setbeamerfont{footline}{size=\scriptsize}

% Remove Beamer navigation symbols everywhere
\setbeamertemplate{navigation symbols}{}

% Itemize bullets as small filled circles in HSG green
\setbeamertemplate{itemize item}{\footnotesize$\bullet$}
\setbeamertemplate{itemize subitem}{\scriptsize$\bullet$}

% ---------------------------------------------------------------------------
% Course footer. Usage in the preamble:   \coursefooter{Computer Networks}
% Leave unset to show only "School of Computer Science | University of St. Gallen"
% ---------------------------------------------------------------------------
\def\@hsgcoursefooter{}
\newcommand{\coursefooter}[1]{\def\@hsgcoursefooter{#1}}

% ---------------------------------------------------------------------------
% Frame title: small muted-grey topic tag above a larger regular-weight title.
% HSG green is RESERVED for the sidebar current-section marker, the chrome
% badge, and inline emphasis (\hsgemph). It must NEVER be used for frame
% titles, frame subtitles, column headers, or any heading-like text on a
% slide — that would clash with the sidebar's progress cue.
% ---------------------------------------------------------------------------
\setbeamercolor{framesubtitle}{fg=HSGmuted}
\setbeamertemplate{frametitle}{%
  \vspace{0.35cm}%
  \noindent%
  {\usebeamercolor[fg]{framesubtitle}\usebeamerfont{framesubtitle}%
   \ifx\insertframesubtitle\@empty\vphantom{Xy}\else\insertframesubtitle\fi\par}%
  \vspace{-0.10em}%
  \noindent{\usebeamerfont{frametitle}\insertframetitle\par}%
  \vspace{0.20em}%
}

% ---------------------------------------------------------------------------
% Slide-area contract. Every slide is divided into three zones.
%
%   +-----------------------------------------+  y = 0 (top)
%   |  HEADER  (frame title + framesubtitle)  |  height = \hsg@headerheight
%   +-----------------------------------------+  y = 2.00 cm
%   |                                         |
%   |  CONTENT  (maximised usable area)       |  height = \hsg@contentheight
%   |                                         |
%   +-----------------------------------------+  y = 8.00 cm
%   |  FOOTER   (logo bottom-L, badge bottom-R)|  height = \hsg@footerheight
%   +-----------------------------------------+  y = 9.00 cm (bottom)
%
%   Horizontal margins: 1.0 cm on left and right -> text width 14.0 cm.
%
% Content fills the full area between HEADER and FOOTER without overlap.
% ---------------------------------------------------------------------------
\newlength{\hsg@footerheight}
\newlength{\hsg@headerheight}
\newlength{\hsg@sidemargin}
\setlength{\hsg@footerheight}{1.00cm}
\setlength{\hsg@headerheight}{2.20cm}
\setlength{\hsg@sidemargin}{1.00cm}

\setbeamersize{%
  text margin left=\hsg@sidemargin,%
  text margin right=\hsg@sidemargin%
}

% ---------------------------------------------------------------------------
% Footer chrome: ONE helper used by ALL non-title layouts so the logo,
% inline progress indicator, and page badge land at IDENTICAL positions
% across the deck.
%
%   - HSG logo at bottom-LEFT: inset \hsg@sidemargin from left.
%   - Inline progress "SECTION · N / M" just right of the logo.
%   - Page-number badge at bottom-RIGHT: square sized for 1-to-3-digit
%     numbers; font automatically scales down for 2+ digits so the digits
%     never touch the badge edge.
% ---------------------------------------------------------------------------
% Minimal section-progress indicator: a tiny row of section numbers
% in the top-right corner. Past sections muted, current bold + green,
% future muted. Takes < 0.5 cm of vertical space and ~0.4 cm per
% section horizontally — invisible until the reader looks for it.
\newif\ifhsg@backup
\hsg@backupfalse

\newcommand{\hsg@progress}{%
  \ifhsg@backup
    \begin{tikzpicture}[remember picture, overlay]
      \node[anchor=base east, inner sep=0pt,
            font=\fontsize{5}{6}\selectfont\itshape, text=HSGmuted!60]
        at ([xshift=-0.10cm, yshift=-0.55cm]current page.north east) {appendix};
    \end{tikzpicture}%
  \else
    \ifnum\@hsg@sectotal>0\relax
      \begin{tikzpicture}[remember picture, overlay]
        \foreach \i in {1,...,\@hsg@sectotal} {%
          \pgfmathsetmacro{\hsgxoff}{(\i - \@hsg@sectotal - 1) * 0.30}%
          \ifnum\i=\thehsg@cursec\relax
            \node[anchor=base east, inner sep=0pt,
                  font=\fontsize{6}{7}\selectfont\bfseries, text=HSGgreen]
              at ([xshift=\hsgxoff cm, yshift=-0.55cm]current page.north east) {\i};
          \else
            \node[anchor=base east, inner sep=0pt,
                  font=\fontsize{5}{6}\selectfont, text=HSGmuted!60]
              at ([xshift=\hsgxoff cm, yshift=-0.55cm]current page.north east) {\i};
          \fi
        }%
      \end{tikzpicture}%
    \fi
  \fi
}

\newcommand{\hsg@footerchrome}{%
  \hsg@progress%
  \begin{tikzpicture}[remember picture, overlay]
    % Small HSG logo, bottom-left — sits OUTSIDE the body text area.
    \node[anchor=south west, inner sep=0pt]
      at ([xshift=0.30cm, yshift=0.25cm]current page.south west)
      {\includegraphics[height=0.55cm]{hsg-logo-en.pdf}};
    % Page badge, bottom-right. Geometry copied verbatim from the master:
    % Freeform Shape 6 in slideMaster1.xml — a 5-point trapezoid with
    % size 0.593 x 0.650 cm PPT  ->  0.374 x 0.410 cm Beamer.
    % Polygon path-normalised points (master custGeom):
    %   pt0 (0.0000, 0.2090)  pt1 (1.0000, 0.0000)
    %   pt2 (1.0000, 1.0000)  pt3 (0.1449, 0.9467)  -> close to pt0
    % Page number font: master = 8 pt PPT  ->  5 pt Beamer.
    \node[anchor=south east, inner sep=0pt]
      at ([xshift=-\hsg@sidemargin, yshift=0.30cm]current page.south east)
      {\tikz[baseline=0pt, x=0.374cm, y=-0.410cm, yshift=0.410cm]{%
        % y axis flipped so the master path's (0,0)=top-left maps to the
        % usual TikZ bottom-left baseline.
        \fill[HSGgreen]
          (0.0000, 0.2090) -- (1.0000, 0.0000) --
          (1.0000, 1.0000) -- (0.1449, 0.9467) -- cycle;
        % Centre the page number at the polygon's optical centre.
        % The badge is asymmetric (wider on the right, narrower on the
        % top-left); the number sits at (0.575, 0.555). Font auto-shrinks
        % for 2-/3-digit numbers so the whole digit string fits between
        % the slanted edges.
        \node[white, inner sep=0pt, anchor=center, text=white]
          at (0.575, 0.555)
          {\ifnum\insertframenumber<10\relax
             {\fontsize{5}{6}\selectfont\bfseries\insertframenumber}%
           \else\ifnum\insertframenumber<100\relax
             {\fontsize{4}{5}\selectfont\bfseries\insertframenumber}%
           \else
             {\fontsize{3.2}{4}\selectfont\bfseries\insertframenumber}%
           \fi\fi};
      }};
  \end{tikzpicture}%
}

% ---------------------------------------------------------------------------
% Inline section progress indicator.
%
% Declare the deck's outline ONCE in the preamble with
%   \hsgsetsections{Dataset, Methodology, Results, Acoustic test, Takeaways}
% Then call \hsgsection{Name} right before the first slide of each section
% to advance the progress counter. This does NOT produce a divider slide —
% it just updates the inline footer progress display.
%
% The footer chrome renders:   <HSG-logo>  SECTION · N / M   ...   <page badge>
% so the reader always sees where they are in the deck without a dedicated
% table-of-contents slide.
% ---------------------------------------------------------------------------
\newcounter{hsg@cursec}
\setcounter{hsg@cursec}{0}
\def\@hsg@sections{}
\def\@hsg@sectotal{0}
\def\hsg@currentsectionname{}

\newcommand{\hsgsetsections}[1]{%
  \def\@hsg@sections{#1}%
  \def\@hsg@sectotal{0}%
  \foreach \s in {#1} {%
    \xdef\@hsg@sectotal{\the\numexpr\@hsg@sectotal+1\relax}%
  }%
}

% Minimal vertical progress spine.
%
% Instead of text, the sidebar is a slim vertical rail running the height
% of the content zone. N evenly-spaced notches mark section boundaries.
% The portion of the rail corresponding to sections already passed is
% filled solid HSGgreen; the remainder stays HSGmuted!25. The current
% section is highlighted by a small HSGgreen bullet at its notch.
%
% Sidebar disabled — \hsgsetsections / \hsgsection still accept their
% arguments for backward compatibility but do not render anything.
\setbeamertemplate{sidebar left}{}

% Footline template reserves exactly \hsg@footerheight of vertical space at
% the bottom of each frame, guaranteeing content never reaches the chrome.
\setbeamertemplate{footline}{%
  \begin{beamercolorbox}[wd=\paperwidth, ht=\hsg@footerheight, dp=0pt]{footline}{}\end{beamercolorbox}%
  \hsg@footerchrome%
}

% ---------------------------------------------------------------------------
% Title page
%
% Optional hero image on the right half of the cover. Matches the PowerPoint
% master's "Titel Slide 1" layout. Usage in the preamble:
%
%     \coverimage{path/to/image.jpg}                 % rectangular (default)
%     \coverimage[shape=circle]{path/to/image.jpg}
%     \coverimage[shape=hexagon]{path/to/image.jpg}
%     \coverimage[shape=gear]{path/to/image.jpg}     % 10-toothed cogwheel
%     \coverimage[shape=blob]{path/to/image.jpg}     % organic rounded shape
%
% Leave unset for a text-only cover. When set, the title text narrows to the
% left half automatically so the image has room.
% ---------------------------------------------------------------------------
\RequirePackage{xkeyval}
\RequirePackage{adjustbox}

\def\@hsgcoverimage{}
\def\@hsgcovershape{rect}
\def\@hsgcoverrotate{0}
\define@key{hsgcover}{shape}{\def\@hsgcovershape{#1}}
\define@key{hsgcover}{rotate}{\def\@hsgcoverrotate{#1}}
% \coverimage[options]{path}
%   options: shape={rect|circle|hexagon|gear|blob}
%            rotate=<deg>   apply rotation BEFORE the cover-clip path
%                           (-90 = portrait photo into landscape clip, etc.)
\newcommand{\coverimage}[2][]{%
  \def\@hsgcovershape{rect}%
  \def\@hsgcoverrotate{0}%
  \setkeys{hsgcover}{#1}%
  \def\@hsgcoverimage{#2}%
}

% Title page. Faithfully reproduces slideLayout38.xml "Titel Slide 3" —
% the actual layout used by the HSG PowerPoint template's slide 1.
% All positions scaled from master 25.40 x 14.29 cm to Beamer 16 x 9 cm.
\setbeamertemplate{title page}{%
  \begin{tikzpicture}[remember picture, overlay]
    % HSG logo WITH institute subtitle — top-left, respecting side margin.
    \node[anchor=north west, inner sep=0pt]
      at ([xshift=\hsg@sidemargin, yshift=-0.55cm]current page.north west)
      {\includegraphics[height=0.90cm]{hsg-logo-en.pdf}};

    % LAYER 1 (background): HSG green badge frame — drawn FIRST so the
    % photo overlays it and only a thin L-shaped strip of the badge
    % peeks out along the photo's lower-left diagonal edge.
    %
    % Master positions (slideLayout38 "Titel Slide 3", ×0.630 Beamer scale):
    %   Badge Grafik 20: (15.92, 4.42) size 6.89x7.65 cm  ->  (10.03, 2.78) size 4.34x4.82 cm
    %   Photo Bildplatzhalter 17: (16.03, 1.19) size 9.41x10.62 cm  ->  (10.10, 0.75) size 5.93x6.69 cm
    \ifx\@hsgcoverimage\@empty\else
      \node[anchor=north west, inner sep=0pt]
        at ([xshift=10.03cm, yshift=-2.78cm]current page.north west)
        {\includegraphics[width=4.34cm, height=4.82cm]{hsg-badge.png}};
    \fi

    % LAYER 2 (foreground): Photo with master's 6-point custGeom clip.
    % Master placeholder (16.03, 1.19) 9.41x10.62  ->  Beamer (10.10, 0.75) 5.93x6.69.
    % COVER fit: image is scaled to fill the clip area without distortion
    % (aspect ratio preserved). Any excess is cropped by the clip path.
    \ifx\@hsgcoverimage\@empty\else
      \begin{scope}[shift={([xshift=10.10cm, yshift=-0.75cm]current page.north west)}]
        \clip (5.93cm, 0)
           -- (5.93cm, -6.69cm)
           -- (5.54cm, -6.69cm)
           -- (0.82cm, -6.27cm)
           -- (0, -1.53cm)
           -- (0, -1.48cm) -- cycle;
        \node[anchor=center, inner sep=0pt] at (2.965cm, -3.345cm)
          {\includegraphics[width=12cm, height=12cm, keepaspectratio,
                            angle=\@hsgcoverrotate]{\@hsgcoverimage}};
      \end{scope}
    \fi

    % Title / subtitle / author / institute.
    %
    % Each block sits at a FIXED Y position so the vertical rhythm is
    % constant regardless of content length:
    %
    %   y = 3.00 cm   Title       (max width 9 cm, max height 1.6 cm)
    %   y = 4.80 cm   Subtitle    (max width 9 cm, max height 0.8 cm)
    %   y = 6.10 cm   Author      (max width 9 cm, max height 0.6 cm)
    %   y = 6.80 cm   Institute   (max width 9 cm, max height 1.5 cm)
    %   y = 8.30 cm   Tagline     (always 6 pt)
    %
    % Each block is wrapped in \adjustbox{max totalsize={W}{H}, scale<=1}
    % so long content auto-shrinks to fit the box, but short content
    % renders at its natural design size. This guarantees the cover
    % layout never breaks regardless of how long the title or author
    % string is.

    % Title — single line, auto-shrinks proportionally to fit 9 cm wide.
    % \adjustbox{max width=9cm} measures the natural width; if the title
    % is shorter than 9cm it renders at the design size (22 pt), if
    % longer it shrinks proportionally so the cover layout never breaks.
    \node[anchor=north west, inner sep=0pt, outer sep=0pt]
      at ([xshift=\hsg@sidemargin, yshift=-3.00cm]current page.north west)
      {\adjustbox{max width=8.4cm}{%
        \fontsize{22}{26}\selectfont\color{HSGtext}\inserttitle}};

    \ifx\insertsubtitle\@empty\else
      \node[anchor=north west, inner sep=0pt, outer sep=0pt]
        at ([xshift=\hsg@sidemargin, yshift=-4.20cm]current page.north west)
        {\adjustbox{max width=8.4cm}{%
          \fontsize{14}{17}\selectfont\color{HSGtext}\insertsubtitle}};
    \fi

    \ifx\insertauthor\@empty\else
      \node[anchor=north west, inner sep=0pt, outer sep=0pt]
        at ([xshift=\hsg@sidemargin, yshift=-6.10cm]current page.north west)
        {\adjustbox{max width=8.4cm}{%
          \fontsize{9}{11}\selectfont\color{HSGtext}\insertauthor}};
    \fi

    % Institute often has 2-3 lines so wrap inside a 9 cm minipage and
    % auto-shrink the WHOLE block if its total height exceeds 1.5 cm.
    \ifx\insertinstitute\@empty\else
      \node[anchor=north west, inner sep=0pt, outer sep=0pt]
        at ([xshift=\hsg@sidemargin, yshift=-6.80cm]current page.north west)
        {\adjustbox{max totalsize={8.4cm}{1.5cm}}{%
          \begin{minipage}[t]{8.4cm}
            \setlength{\parindent}{0pt}\setlength{\parskip}{0pt}\raggedright
            \leavevmode{\fontsize{8}{10}\selectfont\color{HSGtext}\insertinstitute\par}%
          \end{minipage}}};
    \fi

    % "From insight to impact" — bottom-left, small (6 pt).
    \node[anchor=north west, inner sep=0pt,
          font=\fontsize{6}{7.5}\selectfont, text=HSGtext]
      at ([xshift=\hsg@sidemargin, yshift=-8.30cm]current page.north west)
      {From insight to impact};
  \end{tikzpicture}%
}

% ---------------------------------------------------------------------------
% Section page (optional, called with \frame{\sectionpage})
% ---------------------------------------------------------------------------
\setbeamertemplate{section page}{%
  \begin{centering}
    \vspace*{1.5cm}
    {\usebeamerfont{framesubtitle}\usebeamercolor[fg]{structure}%
     Section~\insertsectionnumber\par}
    \vspace{0.4em}
    {\usebeamerfont{title}\insertsection\par}
  \end{centering}
}

% ---------------------------------------------------------------------------
% Convenience: green inline emphasis command
% ---------------------------------------------------------------------------
\newcommand{\hsgemph}[1]{{\color{HSGgreen}\textbf{#1}}}

% ---------------------------------------------------------------------------
% \hsgtwocol{left}{right} — symmetric two-column body, top-aligned, equal
% gutters. Use inside any frame for side-by-side content.
% ---------------------------------------------------------------------------
\newcommand{\hsgtwocol}[2]{%
  \begin{columns}[T,onlytextwidth]
    \begin{column}{0.48\textwidth}#1\end{column}
    \begin{column}{0.48\textwidth}#2\end{column}
  \end{columns}%
}

% ---------------------------------------------------------------------------
% \hsgbackup — render an "Appendix" separator slide and switch the
% top-right progress indicator from numeric (1..N) to a quiet "appendix"
% label. Following frames keep counting toward \insertframenumber but no
% longer inflate the section progress shown in the corner.
% ---------------------------------------------------------------------------
\newcommand{\hsgbackup}{%
  \hsg@backuptrue
  \hsgchapter{}{Backup}%
}

% ---------------------------------------------------------------------------
% \hsgbibliography — render a "References" slide that prints the bibliography
% with allowframebreaks so long lists overflow into extra slides cleanly.
% Requires the user to load biblatex in the preamble:
%
%   \usepackage[backend=biber, style=numeric, sorting=none]{biblatex}
%   \addbibresource{refs.bib}
%
% Then place \hsgbibliography just before \hsgclosing or \hsgbackup.
% ---------------------------------------------------------------------------
\newcommand{\hsgbibliography}{%
  \begin{frame}[allowframebreaks,t]
    \frametitle{References}
    \footnotesize
    \printbibliography[heading=none]
  \end{frame}%
}

% ---------------------------------------------------------------------------
% Content area enforcement.
%
% The HSG content slides have fixed chrome (title, footer, badge, logo) that
% consumes vertical space. Usable content area on a Beamer 16x9 slide is
% approximately 14.5 cm wide x 5.5 cm tall after frametitle and footline.
%
% Two mechanisms are provided:
%
%   \begin{frame}[shrink=15] ... \end{frame}
%     Beamer's built-in auto-shrink. Content is rendered at 100%, then
%     if it overflows the frame, it is scaled down by up to 15%.
%
%   \begin{hsgfit} ... \end{hsgfit}
%     Wraps its content in an auto-sizing box that is guaranteed to fit
%     the default content area (14.5 x 5.5 cm). Use when shrink is not
%     enough or for tighter control.
% ---------------------------------------------------------------------------
\newenvironment{hsgfit}{%
  \adjustbox{max totalsize={14.5cm}{5.5cm}, center}\bgroup%
  \begin{minipage}{14.5cm}%
}{%
  \end{minipage}%
  \egroup%
}

% ===========================================================================
% Frame patterns from the HSG PowerPoint master.
% Each command below generates a full frame. Place them inside the document,
% not inside a frame, for example:
%
%     \hsgagenda{Encryption}{Symmetric crypto}{Asymmetric crypto}{TLS}{Summary}
%     \hsgquote{The cloud is just somebody else's computer.}{Anonymous}
