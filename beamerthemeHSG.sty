\newcommand{\hsgcontact}[3]{%
  \begin{frame}
    \frametitle{Contact}
    \vspace{1em}
    \begin{minipage}{0.85\textwidth}
      {\LARGE #1}\par\vspace{0.8em}
      {\normalsize\color{HSGgreen} #2}\par\vspace{0.6em}
      {\small #3}
    \end{minipage}
  \end{frame}%
}

