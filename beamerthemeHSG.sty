% -----------------------------------------------------------------
% Agenda frame: title on the left, numbered list below. Right half
% is reserved for an optional image via \hsgagendaimage{path}.
% -----------------------------------------------------------------
% Default texture image comes from the HSG master (portrait concrete slab).
% Override with \hsgagendaimage{path} or disable with \hsgagendaimage{}.
\def\@hsgagendaimage{hsg-agenda-texture-portrait.jpg}
\newcommand{\hsgagendaimage}[1]{\def\@hsgagendaimage{#1}}

% Agenda layout — matches slideLayout36.xml exactly.
% Master positions (scaled 25.40x14.29 -> 16x9):
%   Title:   (0.63, 0.66) 9.26x1.07 cm
%   Content: (0.63, 2.23) 9.26x5.60 cm (enumerate list on the left)
%   Picture: (10.44, 0.00) 5.56x9.00 cm (full-height, right side)
\newcommand{\hsgagenda}[1]{%
  \begin{frame}[plain]
    \begin{tikzpicture}[remember picture, overlay]
      % Optional full-height image on the right
      \ifx\@hsgagendaimage\@empty\else
        \node[anchor=north west, inner sep=0pt]
          at ([xshift=10.44cm, yshift=0cm]current page.north west)
          {\includegraphics[width=5.56cm, height=9.00cm,
                            keepaspectratio=false]{\@hsgagendaimage}};
      \fi

      % Agenda title at same top-left offset as normal frames.
      \node[anchor=north west, font=\Large\mdseries, text=HSGtext]
        at ([xshift=0.63cm, yshift=-0.66cm]current page.north west)
        {Agenda};

      % Enumerate list positioned at master coordinates.
      % Width depends on whether an agenda image is set.
      \ifx\@hsgagendaimage\@empty
        \def\@hsg@agendawidth{14.74cm}%
      \else
        \def\@hsg@agendawidth{9.26cm}%
      \fi
      \node[anchor=north west, text width=\@hsg@agendawidth, inner sep=0pt]
        at ([xshift=0.63cm, yshift=-2.23cm]current page.north west)
        {%
          \begin{enumerate}
          \setlength\itemsep{0.55em}
          \color{HSGtext}#1
          \end{enumerate}
        };
    \end{tikzpicture}%
    \hsg@footerchrome%  SAME footer as every other content slide
  \end{frame}%
}

% -----------------------------------------------------------------
% Section-divider frame — matches slideLayout37.xml "Titel Slide 2".
% Use between major parts of the talk (Introduction, Methods,
% Results, Conclusion, ...). Produces a left-side title with an
% optional subtitle and a full-height concrete-texture image on
% the right (same texture as the agenda default).
%
%   \hsgsection{Introduction}             -> title only
%   \hsgsection{Methods}{Distributed}     -> title + subtitle line
%
% Override the right-side image: \hsgsectionimage{path}.
% Disable it entirely:           \hsgsectionimage{}.
% -----------------------------------------------------------------
% \hsgsection{Name} — advance to the next section without rendering a
% divider slide. The inline footer progress updates automatically.
% The optional argument (#1) is kept for backward compatibility but
% ignored, since the divider slide was removed.
\def\@hsgsectionimage{hsg-agenda-texture-portrait.jpg}
\newcommand{\hsgsectionimage}[1]{\def\@hsgsectionimage{#1}}
\newcommand{\hsgsection}[2][]{%
  \stepcounter{hsg@cursec}%
  \gdef\hsg@currentsectionname{#2}%
}

% -----------------------------------------------------------------
% Chapter-separator frame — matches slideLayout39/40.xml "Kapiteltrenner".
% Large number + title, optionally over a full-bleed background image.
%
%   \hsgchapter{02}{Methodology}
%   \hsgchapter[images/bg.jpg]{03}{Results}   % optional bg image
% -----------------------------------------------------------------
\newcommand{\hsgchapter}[3][]{%
  \begin{frame}[plain]
    \begin{tikzpicture}[remember picture, overlay]
      \ifthenelse{\equal{#1}{}}{}{%
        \node[anchor=center, inner sep=0pt] at (current page.center)
          {\includegraphics[width=\paperwidth, height=\paperheight,
                            keepaspectratio=false]{#1}};%
      }
      % Large chapter number — bold HSG green
      \node[anchor=north west, inner sep=0pt,
            font=\fontsize{72}{82}\selectfont\bfseries, text=HSGgreen]
        at ([xshift=\hsg@sidemargin, yshift=-2.00cm]current page.north west)
        {#2};
      % Chapter title below
      \node[anchor=north west, inner sep=0pt,
            font=\fontsize{28}{34}\selectfont, text=HSGtext]
        at ([xshift=\hsg@sidemargin, yshift=-5.20cm]current page.north west)
        {#3};
    \end{tikzpicture}%
    \hsg@footerchrome%
  \end{frame}%
}

% -----------------------------------------------------------------
% Quote frame (two flavours: black on white, or white on green).
% \hsgquote{quote}{attribution}          -> black text, white bg
% \hsgquoteinverted{quote}{attribution}  -> white text, green bg
% -----------------------------------------------------------------
\newcommand{\hsgquote}[2]{%
  \begin{frame}[plain]
    \begin{tikzpicture}[remember picture, overlay]
      % tiny logo bottom-left for context
      \node[anchor=south west, xshift=0.7cm, yshift=0.5cm]
        at (current page.south west)
        {\includegraphics[height=0.55cm]{hsg-logo-en.pdf}};
    \end{tikzpicture}%
    \vfill
    \begin{center}
      \begin{minipage}{0.82\textwidth}
        \raggedright
        {\color{HSGgreen}\fontsize{60}{60}\selectfont\textbf{\char`\"}}\\[-1.2em]
        {\LARGE\itshape #1}\par\vspace{1.2em}
        \hfill\emph{#2}
      \end{minipage}
    \end{center}
    \vfill\vfill
  \end{frame}%
}

\newcommand{\hsgquoteinverted}[2]{%
  {\setbeamercolor{background canvas}{bg=HSGgreen}%
   \setbeamercolor{normal text}{fg=white, bg=HSGgreen}%
  \begin{frame}[plain]
    \vfill
    \begin{center}
      \begin{minipage}{0.82\textwidth}
        \color{white}\raggedright
        {\fontsize{60}{60}\selectfont\textbf{\char`\"}}\\[-1.2em]
        {\LARGE\itshape #1}\par\vspace{1.2em}
        \hfill\emph{#2}
      \end{minipage}
    \end{center}
    \vfill\vfill
  \end{frame}}%
}

% -----------------------------------------------------------------
% Statement frame — matches master slideLayout27/29 "Statement 1/2".
%
% Master title placeholder: (2.30, 2.04) PPT size 14.30x10.36, font 79 pt.
% Beamer (×0.630): (1.45, 1.29) cm size 9.01x6.53 cm, 50 pt.
%
% Footer chrome (HSG logo + centred page badge) is preserved so the slide
% carries the same page number as every other content slide.
%
% \hsgstatement{Security is a process, not a product.}
% -----------------------------------------------------------------
\newcommand{\hsgstatement}[1]{%
  \begin{frame}[plain]
    \begin{tikzpicture}[remember picture, overlay]
      \node[anchor=north west, inner sep=0pt]
        at ([xshift=1.45cm, yshift=-1.29cm]current page.north west)
        {\begin{minipage}[t]{13.0cm}
          \setlength{\parindent}{0pt}\raggedright
          {\color{HSGgreen}\fontsize{36}{42}\selectfont\bfseries #1\par}
         \end{minipage}};
    \end{tikzpicture}%
    \hsg@footerchrome%  same logo + page-number badge as every content slide
  \end{frame}%
}

% -----------------------------------------------------------------
% Full-bleed image frame. No footer, small logo bottom-left.
% \hsgfullimage{path/to/image}
% -----------------------------------------------------------------
\newcommand{\hsgfullimage}[1]{%
  \begin{frame}[plain]
    \begin{tikzpicture}[remember picture, overlay]
      \node[anchor=center, inner sep=0pt] at (current page.center)
        {\includegraphics[width=\paperwidth, height=\paperheight,
                          keepaspectratio=false]{#1}};
      \node[anchor=south west, xshift=0.6cm, yshift=0.4cm]
        at (current page.south west)
        {\includegraphics[height=0.5cm]{hsg-logo-en.pdf}};
    \end{tikzpicture}%
  \end{frame}%
}

% -----------------------------------------------------------------
% Closing frame. Faithfully reproduces slideLayout32.xml "31_Contact"
% — the master's closing slide. Full-bleed HSG campus photo with a
% headline overlay top-left (white, large) and a white logo box
% bottom-right.
%   \hsgclosing            -> "Questions?"
%   \hsgclosing{Custom}    -> custom headline
% Uses the bundled hsg-closing-campus.jpg (HSG courtyard, from master).
% Override the photo with \hsgclosingphoto{path}.
% -----------------------------------------------------------------
\def\@hsgclosingtext{Questions?}
\newcommand{\hsgclosingtext}[1]{\def\@hsgclosingtext{#1}}
\def\@hsgclosingphoto{hsg-closing-campus.jpg}
\newcommand{\hsgclosingphoto}[1]{\def\@hsgclosingphoto{#1}}

% Contact info shown inside the translucent white box on the closing slide.
% Defaults to \insertauthor from the title block. Email is optional.
% Override with \hsgclosingcontact{title+name}{email}.
%   e.g. \hsgclosingcontact{Prof. Dr. Bruno Rodrigues}{bruno.rodrigues@unisg.ch}
\def\@hsgclosingcontactname{\insertauthor}
\def\@hsgclosingcontactemail{}
\newcommand{\hsgclosingcontact}[2]{%
  \def\@hsgclosingcontactname{#1}%
  \def\@hsgclosingcontactemail{#2}%
}

\newcommand{\hsgclosing}{%
  \begin{frame}[plain]
    \begin{tikzpicture}[remember picture, overlay]
      % Full-bleed campus photo
      \node[anchor=center, inner sep=0pt] at (current page.center)
        {\includegraphics[width=\paperwidth, height=\paperheight]{\@hsgclosingphoto}};

      % Headline top-left, white, large.
      \node[anchor=north west, inner sep=0pt,
            font=\fontsize{28}{34}\selectfont, text=white]
        at ([xshift=\hsg@sidemargin, yshift=-\hsg@headerheight]current page.north west)
        {\@hsgclosingtext};

      % Translucent contact box — faithful reproduction of slideLayout32
      % "Rechteck 7" from HSG-slide-template.pptx.
      %
      % Master specs (exact values extracted from PPTX XML):
      %   Position (top-left): (6894258, 3008550) EMU = (19.15, 8.36) PPT cm
      %   Size:                (2105677, 1237183) EMU = ( 5.85, 3.44) PPT cm
      %   Fill:  bg1 (white) with alpha=81000  ->  81 % opacity
      %   Border: none
      %   Shadow: outer, blurRad=50800 EMU (1.4 mm), dist=38100 EMU (1.1 mm),
      %           direction 2700000 (shadow cast to bottom-right), alpha 40 %
      %   Text:   no insets (lIns=tIns=rIns=bIns=0), anchored top
      %
      % Beamer (× 16/25.4 = 0.630):
      %   Position: (12.06, 5.27) cm from slide top-left
      %   Size:     3.69 × 2.17 cm
      %
      % Inner HSG logo (master "Rectangle 2", uses image3.png):
      %   Position: (19.54, 8.73) PPT  ->  (12.31, 5.50) Beamer
      %   Size:     (4.09, 0.85)  PPT  ->  ( 2.58, 0.54) Beamer
      %   Offset inside the box: (0.25, 0.23) cm from top-left
      %
      % The box is drawn first as a semi-transparent white rectangle with a
      % subtle shadow; the logo + contact text sit on top.
      % Box shifted 1 cm up relative to master XML (PPT has extra vertical
      % headroom the Beamer 16x9 canvas lacks). Position origin: (12.06, 4.27).
      \begin{scope}[shift={([xshift=12.06cm, yshift=-4.27cm]current page.north west)}]
        \fill[white, opacity=0.81]
          (0, 0) rectangle (3.69cm, -2.17cm);
        % HSG logo at the top of the box (same offset as master).
        \node[anchor=north west, inner sep=0pt]
          at (0.25cm, -0.23cm)
          {\includegraphics[width=2.58cm]{hsg-logo-en.pdf}};
        % Contact text (name bold + email) at 5.5 pt, below the logo.
        \node[anchor=north west, inner sep=0pt,
              text=HSGtext, align=left,
              font=\fontsize{5}{6.5}\selectfont]
          at (0.25cm, -1.05cm)
          {\ifx\@hsgclosingcontactname\@empty\else
             {\bfseries\@hsgclosingcontactname}\\[0.10em]%
           \fi
           \ifx\@hsgclosingcontactemail\@empty\else
             \@hsgclosingcontactemail%
           \fi};
      \end{scope}

      % Bottom strip with EQUIS / AACSB / AMBA accreditation logos and
      % the "From insight to impact" tagline. Extracted from master page 5
      % (slideLayout32) so positions and sizes exactly match the PPT.
      \node[anchor=south west, inner sep=0pt]
        at (current page.south west)
        {\includegraphics[width=\paperwidth]{hsg-closing-logo-band.png}};
    \end{tikzpicture}%
  \end{frame}%
}

% Backward-compat alias for \hsgthanks — now reuses the closing slide.
\newcommand{\hsgthanks}{\hsgclosing}

% -----------------------------------------------------------------
% Contact frame: name, contact details, optional affiliation.
% \hsgcontact{Name}{email}{Affiliation}
